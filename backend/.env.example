# ============================================================================
#  Backend environment — copy to backend/.env (auto-loaded by backend)
# ============================================================================

NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kiosk_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kiosk_dev

REDIS_URL=redis://localhost:6379

JWT_SECRET=please-replace-with-a-long-random-string-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

ALLOWED_EMAILS=admin@phuonglinh.vn,admin@honghanh.vn

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

LOG_LEVEL=info
