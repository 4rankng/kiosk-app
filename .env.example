# Application
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kiosk
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=kiosk_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email allowlist (comma-separated, empty = open)
ALLOWED_EMAILS=

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=info

# Adminer
ADMINER_PORT=8082
