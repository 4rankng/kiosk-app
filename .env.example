# ============================================================================
#  Environment variables — copy to .env (local) or .env.production (prod)
#  All values are placeholders. Replace before running in any environment.
# ============================================================================

# Runtime
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# DATABASE_URL=postgresql://user:pass@host:5432/db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Email allowlist — comma-separated, or empty for open
ALLOWED_EMAILS=

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
